---
// src/pages/limited/board.astro
import Layout from "../../layouts/Layout.astro";
import { client } from "../../lib/microcms";
import type { MicroCMSListResponse } from "../../lib/microcms";

type News = {
    id: string;
    title: string;
    date: string;
    url?: string;
    episode?: string;
    top_image_isLimited?: { url: string };
};

// 掲示板データを取得（最大100件） [cite: 3]
const response = await client.get<MicroCMSListResponse<News>>({
    endpoint: "news",
    queries: {
        fields: ["id", "title", "date", "url", "episode"],
        filters: "date[exists]",
        limit: 100,
    },
});

// スライドショー用画像の取得 [cite: 4]
const sliderResponse = await client.get<MicroCMSListResponse<News>>({
    endpoint: "news",
    queries: {
        fields: ["top_image_isLimited"],
        filters: "top_image_isLimited[exists]",
        limit: 10,
    },
});

const vegasImages = sliderResponse.contents.map((content) => ({
    // @ts-ignore
    src: content.top_image_isLimited.url,
}));
---

<Layout title="LIMITED_BOARD" isLimited={true}>
    <div id="header-placeholder"></div>

    <section id="vidual-area">
        <div id="slider-area" class="bgextend bgRLextendTrigger">
            <div class="bgappearTrigger">
                <div id="slider"></div>
            </div>
        </div>

        <h2>
            <span class="js_typing">Bulletin Board</span><br />
            <span class="js_typing">Archive</span>
        </h2>
        <dl>
            <dt>Follow Us</dt>
            <dd>
                <ul>
                    <li>
                        <a href="https://x.com/momotenguitar">
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 1200 1227"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"
                                    fill="currentColor"></path>
                            </svg>
                        </a>
                    </li>
                    <li>
                        <a href="https://www.instagram.com/mfsc_modern/?hl=ja">
                            <img
                                src="/img/main/ico_insta.svg"
                                alt="Instagram"
                            />
                        </a>
                    </li>
                </ul>
            </dd>
        </dl>
        <div class="scrolldown1"><span>Scroll</span></div>
    </section>

    <main id="main-area">
        <section id="service">
            <h2 class="js_typing">Past Records</h2>
            <p class="service-lead">
                <span class="bgextend bgRLextendTrigger">
                    <span class="bgappearTrigger">掲示板・裏エピアーカイブ</span
                    >
                </span>
            </p>

            <div class="board-container bgextend bgRLextendTrigger">
                <div class="bgappearTrigger dashboard-section">
                    <ul class="limited-news-list" id="pagination-list">
                        {
                            response.contents.map((news) => (
                                <li class="news-item">
                                    {" "}
                                    <time datetime={news.date}>
                                        {new Date(news.date)
                                            .toLocaleDateString("ja-JP", {
                                                year: "numeric",
                                                month: "2-digit",
                                                day: "2-digit",
                                            })
                                            .replace(/\//g, ".")}
                                    </time>
                                    {news.url ? (
                                        <a
                                            href={news.url}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="news-title-link"
                                        >
                                            {news.title?.trim()}
                                        </a>
                                    ) : (
                                        <span class="news-title-text">
                                            {news.title?.trim()}
                                        </span>
                                    )}
                                    {news.episode && (
                                        <div class="episode-box">
                                            <span class="episode-label">
                                                👆裏エピ
                                            </span>
                                            <div
                                                class="episode-content"
                                                set:html={news.episode}
                                            />
                                        </div>
                                    )}
                                </li>
                            ))
                        }
                    </ul>

                    <div id="pagination-nav" class="pagination-container"></div>
                </div>
            </div>

            <div class="back-btn-area">
                <a href="/limited" class="btnlinestretches2"
                    >ダッシュボードに戻る</a
                >
            </div>
        </section>
    </main>

    <script is:inline define:vars={{ vegasImages }}>
        // --- 1. スライダーの設定 (既存) ---
        window.addEventListener("load", function () {
            if (typeof $ === "undefined" || typeof $.fn.vegas === "undefined")
                return;

            const defaultImages = [
                { src: "/img/main/top8.jpg" },
                { src: "/img/main/top9.jpg" },
                { src: "/img/main/top10.jpg" },
            ];
            const finalImages =
                vegasImages.length > 0 ? vegasImages : defaultImages;

            $("#slider").vegas({
                overlay: false,
                transition: "blur",
                transitionDuration: 2000,
                delay: 10000,
                animationDuration: 20000,
                animation: "kenburns",
                slides: finalImages,
                timer: false,
            });
        });

        // --- 2. ページネーションの制御 (新規) ---
        document.addEventListener("DOMContentLoaded", () => {
            const itemsPerPage = 15;
            const listItems = document.querySelectorAll(".news-item");
            const navContainer = document.getElementById("pagination-nav");
            const totalPages = Math.ceil(listItems.length / itemsPerPage);
            let currentPage = 1;

            if (totalPages <= 1) return; // 1ページしかなければ何もしない

            function showPage(page) {
                currentPage = page;
                const start = (page - 1) * itemsPerPage;
                const end = start + itemsPerPage;

                listItems.forEach((item, index) => {
                    item.style.display =
                        index >= start && index < end ? "flex" : "none";
                });

                renderNav();
                // ページ上部（掲示板の開始位置）へスクロール
                const target = document.getElementById("pagination-list");
                if (target)
                    target.scrollIntoView({
                        behavior: "smooth",
                        block: "start",
                    });
            }

            function renderNav() {
                navContainer.innerHTML = "";
                const navTag = document.createElement("nav");
                navTag.className = "pagination-nav-inner";

                for (let i = 1; i <= totalPages; i++) {
                    const btn = document.createElement("button");
                    btn.innerText = i;
                    btn.className = `page-btn ${i === currentPage ? "active" : ""}`;
                    btn.onclick = () => showPage(i);
                    navTag.appendChild(btn);
                }
                navContainer.appendChild(navTag);
            }

            showPage(1); // 初期表示
        });
    </script>

    <style>
        /* (既存のスタイルはそのまま維持) */
        #header-placeholder {
            pointer-events: none !important;
            position: relative;
            z-index: -1;
        }
        :global(#header),
        :global(header),
        :global(.header) {
            z-index: 2147483647 !important;
            position: fixed !important;
            pointer-events: auto !important;
        }
        #vidual-area {
            position: relative;
            z-index: 1 !important;
            pointer-events: none;
        }
        #slider-area {
            pointer-events: none;
            z-index: 0;
        }
        #vidual-area h2 {
            font-size: 3rem;
            line-height: 1.2;
            letter-spacing: 0.1em;
        }

        /* 掲示板デザイン [cite: 53-61] */
        .board-container {
            max-width: 800px;
            margin: 0 auto 50px;
            padding: 0 20px;
        }
        .dashboard-section {
            --bg-color: rgba(255, 255, 255, 0.05);
            --border-color: #555;
            --title-color: #fff;
            --time-color: #aaa;
            --hover-color: #b22222;
            background: var(--bg-color);
            border-top: 3px solid var(--border-color);
            border-radius: 4px;
            padding: 30px;
        }
        :global(body.light-mode) .dashboard-section {
            --bg-color: #f9f9f9;
            --border-color: #ccc;
            --title-color: #333;
            --time-color: #888;
        }
        .limited-news-list {
            padding: 0;
            list-style: none;
            margin: 0;
        }
        .limited-news-list li {
            padding: 20px 0;
            border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        /* ▼ ページネーション用スタイル (追加) ▼ */
        .pagination-container {
            margin-top: 40px;
            display: flex;
            justify-content: center;
        }
        .pagination-nav-inner {
            display: flex;
            border: 1px solid #ccc;
            border-radius: 6px;
            overflow: hidden;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }
        .page-btn {
            width: 45px;
            height: 45px;
            background: #e0e0e0;
            border: none;
            border-right: 1px solid #ccc;
            color: #333;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .page-btn:last-child {
            border-right: none;
        }
        .page-btn:hover {
            background: #d8d8d8;
        }
        .page-btn.active {
            background: #f44336; /* アクティブな赤色 */
            color: #fff;
            font-weight: bold;
            pointer-events: none;
        }

        :global(body.light-mode) .page-btn {
            background: #f1f1f1;
        }
        :global(body.light-mode) .page-btn:hover {
            background: #e5e5e5;
        }

        /* 裏エピソード [cite: 68-74] */
        .episode-box {
            margin-top: 10px;
            padding: 15px;
            background: rgba(255, 255, 255, 0.05);
            border-left: 4px solid #ffcc00;
            border-radius: 4px;
            width: 100%;
        }
        .episode-label {
            font-size: 0.8rem;
            color: #ffcc00;
            font-weight: bold;
        }
        .episode-content {
            font-size: 0.9rem;
            color: #aeaeae;
            line-height: 1.6;
        }

        .back-btn-area {
            text-align: center;
            margin-top: 40px;
        }
    </style>
</Layout>
