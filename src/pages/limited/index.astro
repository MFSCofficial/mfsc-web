---
// src/pages/limited/index.astro
import Layout from "../../layouts/Layout.astro";
import { client } from "../../lib/microcms";
import type { MicroCMSListResponse } from "../../lib/microcms";

// ▼ ニュース＆画像の型定義
type News = {
    id: string;
    title: string;
    date: string;
    url?: string;
    episode?: string; // やらかしエピソード用
    top_image_isLimited?: { url: string };
};

// ▼ 1. ニュース一覧用
const response = await client.get<MicroCMSListResponse<News>>({
    endpoint: "news",
    queries: {
        fields: ["id", "title", "date", "url", "episode"],
        filters: "date[exists]",
        limit: 3,
    },
});

// ▼ 2. スライドショー用画像の取得
const sliderResponse = await client.get<MicroCMSListResponse<News>>({
    endpoint: "news",
    queries: {
        fields: ["top_image_isLimited"],
        filters: "top_image_isLimited[exists]",
        limit: 10,
    },
});

const vegasImages = sliderResponse.contents.map((content) => ({
    // @ts-ignore
    src: content.top_image_isLimited.url,
}));
---

<Layout title="LIMITED_MAIN" isLimited={true}>
    <div id="header-placeholder"></div>

    <section id="vidual-area">
        <div id="slider-area" class="bgextend bgRLextendTrigger">
            <div class="bgappearTrigger">
                <div id="slider"></div>
            </div>
        </div>

        <h2>
            <span class="js_typing">Modern Folk Song Club</span><br /><span
                class="js_typing">Limited</span
            >
        </h2>
        <dl>
            <dt>Follow Us</dt>
            <dd>
                <ul>
                    <li>
                        <a href="https://x.com/momotenguitar">
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 1200 1227"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"
                                    fill="currentColor"></path>
                            </svg>
                        </a>
                    </li>
                    <li>
                        <a href="https://www.instagram.com/mfsc_modern/?hl=ja">
                            <img
                                src="/img/main/ico_insta.svg"
                                alt="Instagram"
                            />
                        </a>
                    </li>
                </ul>
            </dd>
        </dl>
        <div class="scrolldown1"><span>Scroll</span></div>
    </section>

    <main id="main-area">
        <section id="service">
            <h2 class="js_typing">Members Only</h2>
            <p class="service-lead">
                <span class="bgextend bgRLextendTrigger">
                    <span class="bgappearTrigger"
                        >こちらは部員限定エリアです。</span
                    >
                </span>
            </p>

            <div class="limited-menu-container">
                <a
                    href="/limited/members"
                    class="menu-card bgextend bgLRextendTrigger"
                >
                    <div class="bgappearTrigger card-inner">
                        <div class="card-icon">
                            <img src="/img/main/top1.jpg" alt="Member Icon" />
                        </div>
                        <div class="card-content">
                            <h3>MEMBERS</h3><p>部員紹介</p>
                        </div>
                        <div class="card-arrow">→</div>
                    </div>
                </a>
                <a
                    href="/limited/gallery"
                    class="menu-card bgextend bgLRextendTrigger"
                >
                    <div class="bgappearTrigger card-inner">
                        <div class="card-icon">
                            <img src="/img/main/top2.jpg" alt="Gallery Icon" />
                        </div>
                        <div class="card-content">
                            <h3>GALLERY</h3><p>活動写真</p>
                        </div>
                        <div class="card-arrow">→</div>
                    </div>
                </a>
                <a
                    href="/limited/live"
                    class="menu-card bgextend bgLRextendTrigger"
                >
                    <div class="bgappearTrigger card-inner">
                        <div class="card-icon">
                            <img src="/img/main/top3.jpg" alt="Live Icon" />
                        </div>
                        <div class="card-content">
                            <h3>LIVE INFO</h3><p>ライブ情報</p>
                        </div>
                        <div class="card-arrow">→</div>
                    </div>
                </a>
                <a
                    href="/limited/schedule"
                    class="menu-card bgextend bgLRextendTrigger"
                >
                    <div class="bgappearTrigger card-inner">
                        <div class="card-icon">
                            <img src="/img/main/top4.jpg" alt="Schedule Icon" />
                        </div>
                        <div class="card-content">
                            <h3>SCHEDULE</h3><p>スケジュール</p>
                        </div>
                        <div class="card-arrow">→</div>
                    </div>
                </a>
            </div>

            <div class="dashboard-grid bgextend bgRLextendTrigger">
                <div class="bgappearTrigger dashboard-inner">
                    <div class="dashboard-section section-news">
                        <h3>📌 連絡事項・掲示板</h3>
                        <ul class="limited-news-list">
                            {
                                response.contents.map((news) => (
                                    <li>
                                        <time datetime={news.date}>
                                            {new Date(news.date)
                                                .toLocaleDateString("ja-JP", {
                                                    year: "numeric",
                                                    month: "2-digit",
                                                    day: "2-digit",
                                                })
                                                .replace(/\//g, ".")}
                                        </time>

                                        {news.url ? (
                                            <a
                                                href={news.url}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="news-title-link"
                                            >
                                                {news.title?.trim()}
                                            </a>
                                        ) : (
                                            <span class="news-title-text">
                                                {news.title?.trim()}
                                            </span>
                                        )}

                                        {news.episode && (
                                            <div class="episode-box">
                                                <span class="episode-label">
                                                    裏エピ
                                                </span>
                                                <div
                                                    class="episode-content"
                                                    set:html={news.episode}
                                                />
                                            </div>
                                        )}
                                    </li>
                                ))
                            }
                        </ul>

                        <div class="more-link-area">
                            <a href="/limited/board" class="more-link-btn"
                                >過去の掲示板をもっと見る ➔</a
                            >
                        </div>
                    </div>

                    <div class="dashboard-section section-manuals">
                        <h3>🎸 機材・スタジオマニュアル</h3>
                        <ul class="manual-list">
                            <li>
                                <a href="#" target="_blank">
                                    <div class="manual-icon">🔌</div>
                                    <div class="manual-text">
                                        <h4>スタジオ配線ガイド</h4>
                                        <p>正しいケーブルの繋ぎ方・片付け方</p>
                                    </div>
                                </a>
                            </li>
                            <li>
                                <a href="#" target="_blank">
                                    <div class="manual-icon">🎛️</div>
                                    <div class="manual-text">
                                        <h4>PAミキサーの使い方</h4>
                                        <p>
                                            音出しから電源オフまでの安全な手順
                                        </p>
                                    </div>
                                </a>
                            </li>
                            <li>
                                <a href="#" target="_blank">
                                    <div class="manual-icon">🔊</div>
                                    <div class="manual-text">
                                        <h4>アンプセッティング集</h4>
                                        <p>JC-120やMarshallの基本的な音作り</p>
                                    </div>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="dashboard-section section-downloads">
                        <h3>📝 フォーマット・ダウンロード</h3>
                        <ul class="download-links">
                            <li>
                                <a href="/files/setting_sheet.pdf" download
                                    >📥 セット図フォーマット [PDF]</a
                                >
                            </li>
                            <li>
                                <a
                                    href="/files/setting_sheet_example.pdf"
                                    download
                                    >📥 セット図フォーマット（記入例） [PDF]</a
                                >
                            </li>
                            <li>
                                <a href="#" download
                                    >📥 MFSC 機材リスト一覧表 [PDF]</a
                                >
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
        <section id="contact"></section>
    </main>

    <script is:inline define:vars={{ vegasImages }}>
        window.addEventListener("load", function () {
            if (typeof $ === "undefined" || typeof $.fn.vegas === "undefined") {
                console.error("Vegas or jQuery not loaded");
                return;
            }

            const defaultImages = [
                { src: "/img/main/top8.jpg" },
                { src: "/img/main/top9.jpg" },
                { src: "/img/main/top10.jpg" },
            ];
            const finalImages =
                vegasImages.length > 0 ? vegasImages : defaultImages;

            $("#slider").vegas({
                overlay: false,
                transition: "blur",
                transitionDuration: 2000,
                delay: 10000,
                animationDuration: 20000,
                animation: "kenburns",
                slides: finalImages,
                timer: false,
            });
        });
    </script>

    <style>
        /* ============================================================
           既存のスタイル（ヘッダー、メニューカード等）
           ============================================================ */
        #header-placeholder {
            pointer-events: none !important;
            position: relative;
            z-index: -1;
        }
        :global(#header),
        :global(header),
        :global(.header) {
            z-index: 2147483647 !important;
            position: fixed !important;
            pointer-events: auto !important;
        }
        :global(#header a),
        :global(header a),
        :global(.header a),
        :global(#search-btn),
        :global(.search-btn) {
            pointer-events: auto !important;
            z-index: 2147483647 !important;
            cursor: pointer !important;
        }

        #vidual-area dl dd ul li a svg {
            fill: currentColor;
            color: #fff;
        }
        :global(body.light-mode) #vidual-area dl dd ul li a svg {
            color: #333;
        }

        #vidual-area {
            position: relative;
            z-index: 1 !important;
            pointer-events: none;
        }
        #slider-area {
            pointer-events: none;
            z-index: 0;
        }
        #vidual-area .scrolldown1 {
            pointer-events: auto;
            cursor: pointer;
        }

        .limited-menu-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            max-width: 1000px;
            margin: 50px auto;
            padding: 0 20px;
        }

        .menu-card {
            display: block;
            text-decoration: none;
            color: #fff;
            background: #222;
            border-radius: 4px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
            transition:
                transform 0.3s,
                box-shadow 0.3s,
                background 0.3s;
            position: relative;
        }
        .menu-card .bgappearTrigger {
            height: 100%;
        }
        .card-inner {
            padding: 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255, 255, 255, 0.05);
            height: 100%;
            border-left: 5px solid #555;
            transition: all 0.3s;
        }

        .menu-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
        }
        .menu-card:hover .card-inner {
            border-left-color: #b22222;
            background: rgba(255, 255, 255, 0.1);
        }
        .card-icon {
            width: 60px;
            height: 60px;
            margin-right: 20px;
            border-radius: 50%;
            overflow: hidden;
            border: 2px solid #555;
            box-sizing: border-box;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition:
                border-color 0.3s,
                transform 0.3s;
        }
        .card-icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .menu-card:hover .card-icon {
            border-color: #b22222;
            transform: scale(1.1);
        }
        .card-content {
            flex-grow: 1;
        }
        .card-content h3 {
            font-size: 1.4rem;
            font-weight: bold;
            margin: 0;
            font-family: "Oswald", sans-serif;
            letter-spacing: 0.05em;
            color: #fff;
            transition: color 0.3s;
        }
        .card-content p {
            font-size: 0.85rem;
            color: #aaa;
            margin: 5px 0 0;
            transition: color 0.3s;
        }
        .card-arrow {
            font-size: 1.5rem;
            color: #555;
            margin-left: 15px;
            transition:
                transform 0.3s,
                color 0.3s;
        }
        .menu-card:hover .card-arrow {
            color: #b22222;
            transform: translateX(5px);
        }

        /* ライトモード対応 */
        :global(body.light-mode) .menu-card {
            background: #fff;
            color: #333;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }
        :global(body.light-mode) .card-inner {
            background: rgba(0, 0, 0, 0.02);
            border-left-color: #ccc;
        }
        :global(body.light-mode) .menu-card:hover {
            box-shadow: 0 10px 25px rgba(0, 102, 204, 0.2);
        }
        :global(body.light-mode) .menu-card:hover .card-inner {
            border-left-color: #0066cc;
            background: #fff;
        }
        :global(body.light-mode) .card-content h3 {
            color: #333;
        }
        :global(body.light-mode) .card-content p {
            color: #666;
        }
        :global(body.light-mode) .card-icon {
            border-color: #ccc;
        }
        :global(body.light-mode) .menu-card:hover .card-icon {
            border-color: #0066cc;
        }
        :global(body.light-mode) .card-arrow {
            color: #ccc;
        }
        :global(body.light-mode) .menu-card:hover .card-arrow {
            color: #0066cc;
        }

        @media (max-width: 768px) {
            .limited-menu-container {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            .card-inner {
                padding: 20px;
            }
            .card-icon {
                width: 50px;
                height: 50px;
                margin-right: 15px;
            }
            .card-content h3 {
                font-size: 1.2rem;
            }
        }

        /* ============================================================
           ▼▼▼ ダッシュボード ▼▼▼
           ============================================================ */

        .dashboard-grid .bgappearTrigger.dashboard-inner {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            max-width: 1000px;
            margin: 0 auto 50px;
            padding: 0 20px;
        }

        .dashboard-section {
            --bg-color: rgba(255, 255, 255, 0.05);
            --border-color: #555;
            --title-color: #fff;
            --text-color: #ddd;
            --time-color: #aaa;
            --hover-color: #b22222;
            --item-bg: rgba(0, 0, 0, 0.3);

            background: var(--bg-color);
            border-top: 3px solid var(--border-color);
            border-radius: 4px;
            padding: 25px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
            text-align: left;
            transition:
                background 0.3s,
                border-color 0.3s;
        }

        :global(body.light-mode) .dashboard-section {
            --bg-color: #f9f9f9;
            --border-color: #ccc;
            --title-color: #333;
            --text-color: #555;
            --time-color: #888;
            --hover-color: #0066cc;
            --item-bg: rgba(0, 0, 0, 0.03);

            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        }

        .section-downloads {
            grid-column: 1 / -1;
        }

        .dashboard-section h3 {
            font-size: 1.2rem;
            color: var(--title-color);
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 10px;
        }
        :global(body.light-mode) .dashboard-section h3 {
            border-bottom-color: rgba(0, 0, 0, 0.05);
        }

        /* --- ① 掲示板用スタイル --- */
        .limited-news-list {
            padding: 0;
            list-style: none;
            margin: 0;
            text-align: left !important;
        }
        .limited-news-list li {
            padding: 15px 0;
            border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: flex-start;
            gap: 5px;
        }
        :global(body.light-mode) .limited-news-list li {
            border-bottom-color: rgba(0, 0, 0, 0.05);
        }

        .limited-news-list time {
            font-size: 0.85rem;
            color: var(--time-color);
            font-family: "Oswald", sans-serif;
            letter-spacing: 0.05em;
            display: block;
            margin: 0;
            line-height: 1;
        }
        .news-title-link,
        .news-title-text {
            font-size: 1rem;
            color: var(--title-color);
            text-decoration: none;
            display: block;
            text-align: left;
            width: 100%;
            line-height: 1.5;
            margin: 0;
            padding: 0;
        }
        .news-title-link:hover {
            color: var(--hover-color);
            opacity: 0.7;
        }

        /* ★修正：やらかしエピソード用スタイル（Astroの罠突破版） */
        .episode-box {
            margin-top: 8px;
            padding: 12px;
            background: rgba(255, 255, 255, 0.05);
            border-left: 4px solid #ffcc00;
            border-radius: 4px;
            width: 100%;
            box-sizing: border-box;
            text-align: left !important;
        }
        :global(body.light-mode) .episode-box {
            background: rgba(0, 0, 0, 0.03);
            border-left-color: #ffaa00;
        }
        .episode-label {
            display: inline-block;
            font-size: 0.75rem;
            color: #ffcc00;
            margin-bottom: 5px;
            font-weight: bold;
        }
        :global(body.light-mode) .episode-label {
            color: #d97700;
        }

        .episode-content {
            font-size: 0.85rem;
            color: var(--text-color);
            line-height: 1.6;
        }

        /* ▼▼▼ Astroの罠を突破する魔法の書き方 :global() ▼▼▼ */
        .episode-content :global(p) {
            margin: 0 !important;
            padding: 0 !important;
        }
        /* もしmicroCMS側で先頭に無駄な改行や空行が入っていても強制的に消し飛ばす */
        .episode-content :global(br:first-child),
        .episode-content :global(p:empty) {
            display: none !important;
        }

        /* もっと見るボタン用スタイル */
        .more-link-area {
            margin-top: 20px;
            text-align: right;
        }
        .more-link-btn {
            display: inline-block;
            font-size: 0.9rem;
            color: var(--time-color);
            text-decoration: none;
            transition: color 0.3s;
            font-weight: bold;
        }
        .more-link-btn:hover {
            color: var(--hover-color);
        }

        /* --- ② 機材・マニュアル用スタイル --- */
        .manual-list {
            padding: 0;
            list-style: none;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .manual-list a {
            display: flex;
            align-items: center;
            background: var(--item-bg);
            padding: 12px 15px;
            border-radius: 4px;
            color: var(--title-color);
            text-decoration: none;
            transition:
                background 0.3s,
                transform 0.2s;
            border-left: 3px solid transparent;
        }
        .manual-list a:hover {
            transform: translateX(3px);
            background: rgba(178, 34, 34, 0.2);
            border-left-color: var(--hover-color);
        }
        :global(body.light-mode) .manual-list a {
            background: rgba(0, 0, 0, 0.03);
        }
        :global(body.light-mode) .manual-list a:hover {
            background: rgba(0, 102, 204, 0.1);
            border-left-color: var(--hover-color);
        }

        .manual-icon {
            font-size: 1.5rem;
            margin-right: 15px;
            min-width: 30px;
            text-align: center;
        }
        .manual-text h4 {
            margin: 0 0 3px 0;
            font-size: 0.95rem;
            color: var(--title-color);
            transition: color 0.3s;
        }
        .manual-text p {
            margin: 0;
            font-size: 0.8rem;
            color: var(--text-color);
        }
        .manual-list a:hover .manual-text h4 {
            color: var(--hover-color);
        }

        /* --- ③ ダウンロードリンク用スタイル --- */
        .download-links {
            padding: 0;
            list-style: none;
            margin: 0;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }
        .download-links a {
            display: block;
            padding: 15px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 4px;
            color: var(--title-color);
            text-decoration: none;
            transition:
                background 0.3s,
                transform 0.2s;
            font-size: 0.9rem;
        }

        .download-links a:hover {
            transform: translateX(3px);
            background: rgba(178, 34, 34, 0.2);
            color: var(--hover-color);
        }
        :global(body.light-mode) .download-links a {
            background: rgba(0, 0, 0, 0.03);
        }
        :global(body.light-mode) .download-links a:hover {
            background: rgba(0, 102, 204, 0.1);
            color: var(--hover-color);
        }

        /* レスポンシブ対応 */
        @media (max-width: 768px) {
            .dashboard-grid .bgappearTrigger.dashboard-inner {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            .section-downloads {
                grid-column: auto;
            }
            .download-links {
                grid-template-columns: 1fr;
            }
            .dashboard-section {
                padding: 20px;
            }
        }
    </style>
</Layout>
